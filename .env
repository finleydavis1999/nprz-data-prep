# Local-dev environment. Committed because all values are dev defaults
# (the Better Auth secret matches the one in playwright.config.js, and the
# Protomaps key is PUBLIC_-prefixed and bundled into the client JS anyway).
DATABASE_URL=local.db
ORIGIN=http://localhost:5173

# Better Auth — replace with a 32+ char high-entropy string for production.
BETTER_AUTH_SECRET=dev-secret-32-chars-padding-okok

# Dev convenience: bypass the /login redirect entirely. NEVER set in production.
AUTH_DISABLED=true

# Protomaps API key (https://protomaps.com/api). Bundled into the client JS via
# the PUBLIC_ prefix; not actually secret, but kept out of source.
PUBLIC_PROTOMAPS_API_KEY=b20f1204b39252e6
