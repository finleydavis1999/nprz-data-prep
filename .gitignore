# =============================================================================
# .gitignore — NPRZ Spatial Analysis App
# =============================================================================

# ── R environment ─────────────────────────────────────────────────────────────
.Rhistory
.RData
.RDataTmp
.Rproj.user/
*.RData

# ── R data directories (re-generated by scripts, not committed) ───────────────
data/raw/
data/processed/
data/export/
data/sample/

# ── Large/intermediate geo and data files ─────────────────────────────────────
*.duckdb
*.gpkg
*.zip
*.xlsx
*.ini

# GeoJSON files are large — only commit those the app actually serves
*.geojson

# ── Node / SvelteKit ──────────────────────────────────────────────────────────
node_modules/
app-development/node_modules/
app-development/.svelte-kit/

# ── System files ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Scratch / legacy files ────────────────────────────────────────────────────
directory_structure.txt
cbs-map/
static - Shortcut.lnk
app-development/

# ── Aggregated CBS parquets (commit only when full national data is ready) ────
static/data/parquet/cbs-*.parquet

# ── Grid and buurt GeoJSONs (commit only when full national versions ready) ───
static/data/geo/buurt_2024.geojson
static/data/geo/grid_100m_rijnmond.geojson
static/data/geo/grid_500m_rijnmond.geojson