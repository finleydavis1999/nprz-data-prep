# =============================================================================
# .gitignore — NPRZ Spatial Analysis App
# =============================================================================

# ── R environment ─────────────────────────────────────────────────────────────
.Rhistory
.RData
.RDataTmp
.Rproj.user/
*.RData

# ── Raw data (re-generated by scripts, not committed) ─────────────────────────
raw-data/
data/raw/

# ── Large/intermediate files ──────────────────────────────────────────────────
*.duckdb
*.gpkg
*.zip
*.xlsx
*.ini
*.parquet

# ── GeoJSON — only app-served ones committed via explicit git add ─────────────
*.geojson

# ── Node / SvelteKit ──────────────────────────────────────────────────────────
node_modules/
.svelte-kit/

# ── System files ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
local.db

# ── Test/temp files ───────────────────────────────────────────────────────────
test-download*.parquet