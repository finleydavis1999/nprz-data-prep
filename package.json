{
	"name": "nprz-app",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "(svelte-kit sync || true) && (git config core.hooksPath .githooks 2>/dev/null || true)",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest --passWithNoTests",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"test:e2e:install": "playwright install",
		"data": "Rscript R/build.R",
		"users:seed": "node scripts/seed-users.js"
	},
	"dependencies": {
		"@duckdb/duckdb-wasm": "^1.33.1-dev45.0",
		"better-auth": "~1.4.21",
		"better-sqlite3": "^12.0.0",
		"chroma-js": "^3.2.0",
		"d3-geo": "^3.1.1",
		"maplibre-gl": "^5.24.0",
		"mathjs": "^15.2.0",
		"pmtiles": "^4.4.1",
		"protomaps-themes-base": "^4.5.0",
		"simple-statistics": "^7.8.9",
		"svelteplot": "^0.14.2",
		"topojson-client": "^3.1.0"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^22",
		"@vitest/browser-playwright": "^4.1.3",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"playwright": "^1.59.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.2",
		"tailwindcss": "^4.2.2",
		"vite": "^8.0.7",
		"vitest": "^4.1.3",
		"vitest-browser-svelte": "^2.1.0"
	}
